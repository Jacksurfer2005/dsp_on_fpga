module wave_wrapper(
 input clk,
 input rst,
 input enable,
 input signed [23:0] wave_in,
 input signed [23:0] noise_in,
 input [2:0] wave_in_wrapper,
 input [2:0] amp_wrapper,
 input [1:0] dc_wrapper,
 input [1:0] noise_sel, 
 input [2:0] noise_amp,
 output reg signed [23:0] wave_wrapper
 
);
 wave_gen u_wave_gen(
  .clk (clk),
  .rst (rst),
  .wave_sel (wave_in_wrapper),
  .wave_amp (amp_wrapper),
  .dc_in (dc_wrapper),
  .wave_final (wave_in)
);

 noise_top u_noise_top(
  .clk_t (clk),
  .rst_t (rst),
  .sel_n (noise_sel),
  .sel_amp (noise_amp),
  .top_o (noise_in)
);

always@(posedge clk)
 begin
   if(rst) 
	  wave_wrapper <= 0;
	else if (enable)
         wave_wrapper <= wave_in;
   else
         wave_wrapper <= wave_in + noise_in;
		end
	
endmodule	