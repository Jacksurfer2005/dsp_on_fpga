`timescale 1ns / 1ps

module noise_freq_tb(
);

  reg clk_tb;
  reg [1:0] sel_tb;
  wire noise_freq_o;
 
 noise_freq dut (clk_tb,sel_tb,noise_freg_o);
 
 initial
  clk_tb = 0;
   
 always #2.5 clk_tb = ~clk_tb;
 
 initial begin
 sel_tb = 2'b00;
 #10;
 
 sel_tb = 2'b01;
 #10;
 
 sel_tb = 2'b10;
 #10;
 
 sel_tb = 2'b11;
 #10;
 
end

endmodule