module noise_top_tb(
);

 reg clk_top_tb;
 reg rst_top_tb;
 reg [1:0] sel_n_tb;
 reg [2:0] sel_amp_tb;
 wire signed [23:0] top_o_tb;
 
 initial
  begin
    clk_top_tb = 0;
	 rst_top_tb = 1;
	  end
	  
 always#5 clk_top_tb = ~clk_top_tb;
 
 initial 
  begin
   clk_top_tb = 0;
	sel_n_tn   = 2'b00;
	sel_amp_tb = 3'b000;
	#100;
	
	clk_top_tb = 1;
	sel_n_tn   = 2'b01;
	sel_amp_tb = 3'b001;
	#10000;
	
	sel_n_tn   = 2'b01;
	sel_amp_tb = 3'b010;
	#10000;
	 end
	 
endmodule